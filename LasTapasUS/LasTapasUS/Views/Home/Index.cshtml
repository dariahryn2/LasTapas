@model IEnumerable<LasTapasUS.Models.MenuItem>
@{
    ViewData["Title"] = "Menu";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #fafafa;
        }

        .menu-card {
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transition: transform 0.2s ease;
        }

            .menu-card:hover {
                transform: translateY(-3px);
            }

        .basket {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 1.5rem;
            position: sticky;
            top: 20px;
        }

        .btn-checkout {
            background-color: #ff4500;
            color: white;
            width: 100%;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
        }

            .btn-checkout:hover {
                background-color: #e63e00;
                color: #fff;
            }

        .category-bar a {
            text-decoration: none;
            color: #ff4500;
            margin-right: 1.5rem;
            font-weight: 500;
        }

            .category-bar a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <!-- logo -->
    <div class="text-center my-3">
        <img src="~/images/logolastapas.png" alt="Las Tapas Logo" style="height: 260px; width: auto;" />
    </div>


    <div class="container my-4">

        <!-- Category nav -->
        <div class="category-bar mb-3">
            <a href="@Url.Action("Index", "Home", new { category = "All Categories" })">All Categories</a>
            <a href="@Url.Action("Index", "Home", new { category = "Cold Tapas" })">Cold Tapas</a>
            <a href="@Url.Action("Index", "Home", new { category = "Hot Tapas" })">Hot Tapas</a>
            <a href="@Url.Action("Index", "Home", new { category = "Land & Sea" })">Land & Sea</a>
            <a href="@Url.Action("Index", "Home", new { category = "Dishes to Share" })">Dishes to Share</a>
            <a href="@Url.Action("Index", "Home", new { category = "Desserts" })">Desserts</a>
        </div>

        <!-- Content -->
        <div>
            <a href="/Orders/Kitchen" class="btn btn-outline-secondary btn-sm"> Kitchen</a>
            <a href="/Orders/Waiter" class="btn btn-outline-secondary btn-sm">Waiter</a>
            <a class="btn btn-outline-danger mt-3" href="/Orders/MyOrders?table=Demo Table">
                View My Orders
            </a>
        </div>
    </div>

    <!-- Main Layout: Menu + Basket -->
    <div class="row">
        <!-- Menu List -->
        <div class="col-lg-8">
            <div class="row g-3">
                @foreach (var item in Model)
                {
                    <div class="col-md-6">
                        <div class="card menu-card p-3">
                            <!-- Gerecht afbeelding -->
                            <img src="@item.ImagePath" alt="@item.Name" class="img-fluid rounded mb-2" style="height:160px; object-fit:cover; width:100%;" />

                            <h6 class="fw-bold">@item.Name</h6>
                            <p class="text-muted mb-2">@item.Description</p>

                            <!-- Allergie icoontjes -->
                            <div class="d-flex flex-wrap mb-2">
                                @foreach (var allergen in item.Allergens)
                                {
                                    <img src="/icons/@(allergen.ToString().ToLower()).png"
                                         alt="@allergen"
                                         title="@allergen"
                                         style="width:22px; height:22px; margin-right:5px;" />
                                }
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">€@item.Price</span>
                                <button class="btn btn-outline-secondary btn-sm"
                                        onclick="addToBasket('@item.Name', '@item.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)')">
                                    +
                                </button>
                            </div>
                        </div>

                    </div>
                }
            </div>
        </div>

            <!-- Basket -->
            <div class="col-lg-4">
                <div class="basket">
                    <h5>Basket</h5>
                    <p class="text-muted">Your basket is empty.</p>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Enter coupon code" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Sub Total:</span>
                        <span>€0,00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Delivery:</span>
                        <span>Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold mb-3">
                        <span>Order Total:</span>
                        <span>€0,00</span>
                    </div>

              
                    <button class="btn btn-checkout" disabled>Checkout · €0,00</button>
            </div>
        </div> 
        <script>
            // Basket array
            let basket = [];

                //add to basket
                    function addToBasket(name, price) {
                // Zoek of het gerecht al in de basket zit
                let existing = basket.find(item => item.name === name);

                if (existing) {
                    existing.quantity += 1; // verhoog aantal
                } else {
                    basket.push({ name: name, price: parseFloat(price), quantity: 1 });
                }

                renderBasket();
            }


            // Render basket HTML
            function renderBasket() {
                const basketDiv = document.querySelector('.basket');
                if (!basketDiv) return;

                let html = '<h5>Basket</h5>';

                if (basket.length === 0) {
                    html += '<p class="text-muted">Your basket is empty.</p>';
                } else {
               basket.forEach((item, index) => {
                const itemTotal = (item.price * item.quantity).toFixed(2);
                const itemTotalFormatted = itemTotal.replace('.', ','); // voor euro-notatie
            html += `
               <li class="d-flex justify-content-between align-items-center mb-1">
                   <div>
                       ${item.name} <span class="text-muted">x${item.quantity}</span>
                   </div>
                   <div>
                       €${itemTotalFormatted}
                       <button onclick="removeFromBasket(${index})" class="btn btn-sm btn-outline-danger ms-2">x</button>
                   </div>
               </li>`;
            });


                    html += '</ul>';
                }

                // Total
                            let total = basket.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            let totalFormatted = total.toFixed(2).replace('.', ',');
            html += `<hr><div class="d-flex justify-content-between fw-bold mb-3"><span>Total:</span><span>€${totalFormatted}</span></div>`;

                // Checkout button
                html += `<button class="btn btn-checkout" ${basket.length === 0 ? 'disabled' : ''} onclick="submitBasket()">Checkout · €${total.toFixed(2)}</button>`;

                basketDiv.innerHTML = html;
            }

            // Remove item from basket
                       function removeFromBasket(index) {
                if (basket[index].quantity > 1) {
                    basket[index].quantity -= 1;
                } else {
                    basket.splice(index, 1);
                }
                renderBasket();
            }


            // Submit basket to server
            function submitBasket() {
                if (basket.length === 0) return;

                // Send via POST
                fetch('/Orders/SubmitBasket', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: basket, table: 'Demo Table' })
                })
                .then(response => {
                    if (response.ok) {
                        // Redirect to order history page
                       window.location.href = '/Orders/MyOrders?table=' + encodeURIComponent('Demo Table');
                    }
                });
            }

            renderBasket(); // initialize basket
        </script>

        </div> 
    
</body>
</html>

