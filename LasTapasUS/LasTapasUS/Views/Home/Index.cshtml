@model IEnumerable<LasTapasUS.Models.MenuItem>
@{
    ViewData["Title"] = "Menu";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #fafafa;
        }

        .menu-card {
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transition: transform 0.2s ease;
        }

            .menu-card:hover {
                transform: translateY(-3px);
            }

        .basket {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 1.5rem;
            position: sticky;
            top: 20px;
        }

        .btn-checkout {
            background-color: #ff4500;
            color: white;
            width: 100%;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
        }

            .btn-checkout:hover {
                background-color: #e63e00;
                color: #fff;
            }

        .category-bar a {
            text-decoration: none;
            color: #ff4500;
            margin-right: 1.5rem;
            font-weight: 500;
        }

            .category-bar a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="container my-4">
        <!-- Category Nav -->
        <div class="category-bar mb-3">
            <a href="@Url.Action("Index", "Home", new { category = "All Categories" })">All Categories</a>
            <a href="@Url.Action("Index", "Home", new { category = "Cold Tapas" })">Cold Tapas</a>
            <a href="@Url.Action("Index", "Home", new { category = "Hot Tapas" })">Hot Tapas</a>
            <a href="@Url.Action("Index", "Home", new { category = "Land & Sea" })">Land & Sea</a>
            <a href="@Url.Action("Index", "Home", new { category = "Dishes to Share" })">Dishes to Share</a>
            <a href="@Url.Action("Index", "Home", new { category = "Desserts" })">Desserts</a>
        </div>

        <!-- Content -->
        <div>
            <a href="/Orders/Kitchen" class="btn btn-outline-secondary btn-sm">👨‍🍳 Kitchen</a>
            <a href="/Orders/Waiter" class="btn btn-outline-secondary btn-sm">🧾 Waiter</a>
        </div>
    </div>

    <!-- Main Layout: Menu + Basket -->
    <div class="row">
        <!-- Menu List -->
        <div class="col-lg-8">
            <div class="row g-3">
                @foreach (var item in Model)
                {
                    <div class="col-md-6">
                        <div class="card menu-card p-3">
                            <h6 class="fw-bold">@item.Name</h6>
                            <p class="text-muted mb-2">@item.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">€@item.Price</span>
                                <button class="btn btn-outline-secondary btn-sm" onclick="addToBasket('@item.Name', @item.Price)">+</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

            <!-- Basket -->
            <div class="col-lg-4">
                <div class="basket">
                    <h5>Basket</h5>
                    <p class="text-muted">Your basket is empty.</p>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Enter coupon code" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Sub Total:</span>
                        <span>€0,00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Delivery:</span>
                        <span>Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold mb-3">
                        <span>Order Total:</span>
                        <span>€0,00</span>
                    </div>
                    <button class="btn btn-checkout" disabled>Checkout · €0,00</button>
            </div>
        </div> 
        <script>
            // Basket array
            let basket = [];

            // Add item to basket
            function addToBasket(name, price) {
                basket.push({ name: name, price: price });
                renderBasket();
            }

            // Render basket HTML
            function renderBasket() {
                const basketDiv = document.querySelector('.basket');
                if (!basketDiv) return;

                let html = '<h5>Basket</h5>';

                if (basket.length === 0) {
                    html += '<p class="text-muted">Your basket is empty.</p>';
                } else {
                    html += '<ul class="list-unstyled">';
                    basket.forEach((item, index) => {
                        html += `<li>${item.name} - €${item.price.toFixed(2)} <button onclick="removeFromBasket(${index})" class="btn btn-sm btn-outline-danger">x</button></li>`;
                    });
                    html += '</ul>';
                }

                // Total
                let total = basket.reduce((sum, item) => sum + item.price, 0);
                html += `<hr><div class="d-flex justify-content-between fw-bold mb-3"><span>Total:</span><span>€${total.toFixed(2)}</span></div>`;

                // Checkout button
                html += `<button class="btn btn-checkout" ${basket.length === 0 ? 'disabled' : ''} onclick="submitBasket()">Checkout · €${total.toFixed(2)}</button>`;

                basketDiv.innerHTML = html;
            }

            // Remove item from basket
            function removeFromBasket(index) {
                basket.splice(index, 1);
                renderBasket();
            }

            // Submit basket to server
            function submitBasket() {
                if (basket.length === 0) return;

                // Send via POST
                fetch('/Orders/SubmitBasket', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ items: basket, table: 'Demo Table' })
                })
                .then(response => {
                    if (response.ok) {
                        // Redirect to waiter page
                        window.location.href = '/Orders/Waiter';
                    }
                });
            }

            renderBasket(); // initialize basket
        </script>

        </div> 
    
</body>
</html>

