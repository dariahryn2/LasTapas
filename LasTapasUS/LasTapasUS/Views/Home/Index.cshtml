@model IEnumerable<LasTapasUS.Models.MenuItem>
@{
    ViewData["Title"] = "Menu";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #fafafa;
        }

        .menu-card {
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transition: transform 0.2s ease;
        }

            .menu-card:hover {
                transform: translateY(-3px);
            }

        .basket {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 1.5rem;
        }

        .btn-checkout {
            background-color: #ff4500;
            color: white;
            width: 100%;
            border-radius: 10px;
            padding: 0.8rem;
            font-weight: 600;
        }

            .btn-checkout:hover {
                background-color: #e63e00;
                color: #fff;
            }

        .category-bar a {
            text-decoration: none;
            color: #ff4500;
            margin-right: 1.5rem;
            font-weight: 500;
        }

            .category-bar a:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="container my-4">
        <!-- Category Nav -->
        <div class="category-bar mb-3">
            <a href="#">All Categories</a>
            <a href="#">Appetizer</a>
            <a href="#">Specials</a>
            <a href="#">Salads</a>
            <a href="#">Seafoods</a>
            <a href="#">Traditional</a>
            <a href="#">Desserts</a>
            <a href="#">Drinks</a>
        </div>

        <!-- Content -->
        <div>
            <a href="/Orders/Kitchen" class="btn btn-outline-secondary btn-sm">👨‍🍳 Kitchen</a>
            <a href="/Orders/Waiter" class="btn btn-outline-secondary btn-sm">🧾 Waiter</a>
        </div>
    </div>

    <!-- Main Layout: Menu + Basket -->
    <div class="row">
        <!-- Menu List -->
        <div class="col-lg-8">
            <div class="row g-3">
                @foreach (var item in Model)
                {
                    <div class="col-md-6">
                        <div class="card menu-card p-3">
                            <h6 class="fw-bold">@item.Name</h6>
                            <p class="text-muted mb-2">@item.Description</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold">€@item.Price</span>
                                <form asp-controller="Orders" asp-action="Create" method="post" class="d-inline">
                                    <input type="hidden" name="table" value="Demo Table" />
                                    <input type="hidden" name="dish" value="@item.Name" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">+</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>}

            <!-- Basket -->
            <div class="col-lg-4">
                <div class="basket">
                    <h5>Basket</h5>
                    <p class="text-muted">Your basket is empty.</p>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Enter coupon code" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Sub Total:</span>
                        <span>€0,00</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Delivery:</span>
                        <span>Free</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between fw-bold mb-3">
                        <span>Order Total:</span>
                        <span>€0,00</span>
                    </div>
                    <button class="btn btn-checkout" disabled>Checkout · €0,00</button>
                </div>
            </div>
        </div>
    
</body>
</html>

