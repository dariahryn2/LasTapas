@model IEnumerable<LasTapasUS.Models.Order>

@{
    ViewData["Title"] = "My Orders";
    var tableName = ViewData["Table"] as string;
    var tableRequired = ViewData["TableRequired"] as bool? ?? false;
}

<div class="container my-4">
    <h2 class="text-danger mb-3">🍽 My Orders</h2>

    @if (tableRequired)
    {
        <div class="alert alert-warning">
            Please enter your table name to view your orders.
        </div>

        <form action="/Orders/MyOrders" method="get" class="mt-3">
            <div class="input-group w-50">
                <input type="text" name="table" placeholder="Enter your table name" class="form-control" />
                <button type="submit" class="btn btn-danger">View Orders</button>
            </div>
        </form>
    }
    else if (!Model.Any())
    {
        <div class="alert alert-info">
            No orders found for table <strong>@tableName</strong>.
        </div>
    }
    else
    {
        <div class="mb-3">
            <h5>Table: <span class="text-danger">@tableName</span></h5>
        </div>

        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Dish</th>
                    <th>Price</th>
                    <th>Ordered At</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Dish</td>
                        <td>€@order.Price.ToString("0.00")</td>
                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
