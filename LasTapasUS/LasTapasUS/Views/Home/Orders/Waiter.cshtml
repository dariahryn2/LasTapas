@model LasTapasUS.Models.WaiterViewModel


<h2>Waiter View</h2>

<!-- Create new order -->
<form asp-action="Create" method="post" class="mb-4">
    <input name="table" placeholder="Table #" required class="form-control d-inline-block w-auto me-2" />

    <select name="dish" class="form-select d-inline-block w-auto me-2">
        @foreach (var item in LasTapasUS.Data.Menu.MenuList)
        {
            <option value="@item.Name">@item.Name (€@item.Price)</option>
        }
    </select>

    <button type="submit" class="btn btn-primary" style="background-color:#ff4500; color:white; border:none;">Add Order</button>
</form>

<!-- Active Orders -->
<h4>Active Orders</h4>
<table class="table table-striped table-bordered">
    <thead class="table-danger">
        <tr>
            <th>ID</th>
            <th>Table</th>
            <th>Dish</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model.ActiveOrders)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.Table</td>
                <td>@o.Dish</td>
                <td>@o.Status</td>
                <td>
                    @if (o.Status == "Prepared")
                    {
                        <form asp-action="MarkServed" method="post">
                            <input type="hidden" name="id" value="@o.Id" />
                            <button type="submit" class="btn btn-success btn-sm">Mark Served</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Served Orders -->
<h4 class="mt-5">Served Orders</h4>
<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Table</th>
            <th>Dish</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model.ServedOrders)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.Table</td>
                <td>@o.Dish</td>
                <td>@o.Status</td>
            </tr>
        }
    </tbody>
</table>

<a href="/Orders/Kitchen">Go to Kitchen View</a>

